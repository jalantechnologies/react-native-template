default_platform(:ios)

platform :ios do
  ###########################################################
  #  CI SIGNING SETUP FOR BOTH PREVIEW AND PRODUCTION     #
  ###########################################################
  desc "Fetch certificates for CI"
  lane :ci_signing_setup do
    match(type: "appstore", readonly: true, keychain_name: "ci.keychain", keychain_password: ENV["IOS_KEYCHAIN_PASSWORD"])
    match(type: "development", readonly: true, keychain_name: "ci.keychain", keychain_password: ENV["IOS_KEYCHAIN_PASSWORD"])
  end

  ###########################################################
  #   PREVIEW DEPLOYMENT (PR BUILDS)                       #
  ###########################################################
  desc "Build and upload to TestFlight"
  lane :pr_deploy do
    require_relative "scripts/ios_testflight_deploy"

    ios_testflight_deploy!(
      pr_number: ENV["PR_NUMBER"],
      app_identifier: ENV["IOS_APP_IDENTIFIER_PREVIEW"],
      xcodeproj: "Boilerplate.xcodeproj",
      scheme: "Boilerplate",
      api_key_id: ENV['IOS_APP_STORE_CONNECT_API_KEY_ID'],
      issuer_id: ENV['IOS_APP_STORE_CONNECT_API_KEY_ISSUER_ID'],
      api_key_b64: ENV['IOS_APP_STORE_CONNECT_API_KEY_B64'],
      keychain_name: "ci.keychain",
      keychain_password: ENV["IOS_KEYCHAIN_PASSWORD"],
      apple_id: ENV["IOS_APPLE_ID"],
      username: ENV["FASTLANE_USER"],
      team_id: ENV["IOS_APP_STORE_TEAM_ID"]
    )
  end

  desc "Cleanup TestFlight build for PR"
  lane :pr_cleanup do
    require_relative "scripts/ios_testflight_cleanup"

    ios_testflight_cleanup!(
      pr_number: ENV["PR_NUMBER"],
      app_identifier: ENV["IOS_APP_IDENTIFIER_PREVIEW"],
      api_key_id: ENV['IOS_APP_STORE_CONNECT_API_KEY_ID'],
      issuer_id: ENV['IOS_APP_STORE_CONNECT_API_KEY_ISSUER_ID'],
      api_key_b64: ENV['IOS_APP_STORE_CONNECT_API_KEY_B64']
    )
  end

  ###########################################################
  #   PRODUCTION DEPLOYMENT                                #
  ###########################################################
  desc "Sync certificates and profiles"
  lane :certs do
    match(app_identifier: ENV["IOS_APP_IDENTIFIER_PRODUCTION"], type: 'appstore', readonly: true)
  end

  desc "Set version number from package.json"
  lane :set_version_from_package_json do
    package_json = load_json(json_path: "../package.json")
    package_version = package_json["version"]
    UI.message("Setting version to #{package_version} from package.json")

    increment_version_number(
      xcodeproj: "Boilerplate.xcodeproj",
      version_number: package_version
    )
  end

  desc "Check if build number is uploadable if not then increment it"
  lane :check_and_inc_build_number do
    version_number = get_version_number(xcodeproj: "Boilerplate.xcodeproj")
    current_build_number = get_build_number(xcodeproj: "Boilerplate.xcodeproj").to_i

    begin
      latest_build_number = app_store_build_number(
        app_identifier: ENV["IOS_APP_IDENTIFIER"],
        version: version_number,
        live: false,
        initial_build_number: current_build_number,
      ).to_i

      if current_build_number <= latest_build_number
        new_build_number = latest_build_number + 1
        UI.message("Incrementing build number to #{new_build_number}")

        increment_build_number(
          xcodeproj: "Boilerplate.xcodeproj",
          build_number: new_build_number.to_s
        )
      else
        UI.success("Current build number (#{current_build_number}) is valid for upload.")
      end
    rescue => e
      if e.to_s.include?("Could not find a build on App Store Connect")
        UI.important("No uploaded builds found for version #{version_number}. Proceeding with initial upload.")
      else
        raise e
      end
    end
  end

  private_lane :build_release do
    app_store_connect_api_key(
      key_id: ENV['IOS_APP_STORE_CONNECT_API_KEY_ID'],
      issuer_id: ENV['IOS_APP_STORE_CONNECT_API_KEY_ISSUER_ID'],
      key_content: ENV['IOS_APP_STORE_CONNECT_API_KEY_B64'],
      is_key_content_base64: true,
    )
    set_version_from_package_json
    check_and_inc_build_number
    certs
    build_app(
      scheme: "Boilerplate",
      workspace: "Boilerplate.xcworkspace",
      configuration: 'Release',
      silent: true,
      clean: true,
    )
  end

  desc "Deploy a new version to the App Store"
  lane :deploy_ios_production do
    setup_ci if ENV['CI']
    build_release
    deliver(
      force: true,
      skip_screenshots: true,
      skip_metadata: true,
      precheck_include_in_app_purchases: false,
    )
  end
end
